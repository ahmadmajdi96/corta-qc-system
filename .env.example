# CORTA QC — Environment variables

# ============ Database ============
DATABASE_URL=postgresql://corta:secret@db:5432/cortaqc

# ============ Authentication ============
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRY=24h
REFRESH_TOKEN_SECRET=replace-with-another-random-string
REFRESH_TOKEN_EXPIRY=7d

# ============ Server ============
PORT=3000
NODE_ENV=production
CORS_ORIGIN=http://localhost:3000

# ============ Logging ============
LOG_LEVEL=info

# ============ Optional SMTP (notifications) ============
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
