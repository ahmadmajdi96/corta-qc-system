# =========================================================
# CORTA QC — Environment variables (self-hosted docker-compose)
# =========================================================

# ---- Database ----
# Full Postgres connection URL. In docker-compose this points to the "db" service.
DATABASE_URL=postgresql://corta:secret@db:5432/cortaqc

# ---- Authentication (JWT + refresh) ----
# Secret used to sign short-lived access tokens. MUST be a long random string in production.
JWT_SECRET=replace-with-a-long-random-string
# Access token lifetime, e.g. "15m", "1h", "24h".
JWT_EXPIRY=24h
# Secret used to sign refresh tokens. MUST differ from JWT_SECRET.
REFRESH_TOKEN_SECRET=replace-with-another-long-random-string
# Refresh token lifetime.
REFRESH_TOKEN_EXPIRY=7d

# ---- HTTP server ----
# Port the Express API listens on inside the container.
PORT=3000
# node environment (production disables verbose stack traces).
NODE_ENV=production
# Comma-separated list of allowed browser origins for CORS.
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ---- Logging ----
# Winston log level: error | warn | info | http | debug
LOG_LEVEL=info

# ---- Optional SMTP (email notifications) ----
# Leave blank to disable outbound email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
